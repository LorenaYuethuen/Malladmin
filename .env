# 服务器配置
NODE_ENV=development
PORT=3000

# 数据库配置 (PostgreSQL)
DB_HOST=localhost
DB_PORT=5432
DB_USER=mall_user
DB_PASSWORD=mall_password
DB_NAME=mall_admin
DB_POOL_MIN=2
DB_POOL_MAX=20

# JWT配置
JWT_SECRET=your_jwt_secret_key_here_change_in_production
JWT_EXPIRES_IN=7d

# CORS配置
CORS_ORIGIN=*

# CDN配置
CDN_BASE_URL=https://cdn.example.com
CDN_ACCESS_KEY=your_cdn_access_key
CDN_SECRET_KEY=your_cdn_secret_key

# Redis配置（可选，用于缓存和限流）
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# 日志配置
LOG_LEVEL=info
LOG_FILE=logs/app.log

# 限流配置
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100

# 文件上传配置
MAX_FILE_SIZE=5242880
MAX_FILES_COUNT=5
ALLOWED_FILE_TYPES=image/jpeg,image/jpg,image/png

# 敏感词过滤
SENSITIVE_WORDS_ENABLED=true
SENSITIVE_WORDS_FILE=config/sensitive-words.txt

# 评论配置
REVIEW_EDIT_TIME_LIMIT_HOURS=24
REVIEW_SOFT_DELETE_RETENTION_DAYS=30
REVIEW_MIN_CONTENT_LENGTH=10
REVIEW_MAX_CONTENT_LENGTH=500

# 外部服务API（示例）
ORDER_SERVICE_URL=http://localhost:4000/api
USER_SERVICE_URL=http://localhost:5000/api
